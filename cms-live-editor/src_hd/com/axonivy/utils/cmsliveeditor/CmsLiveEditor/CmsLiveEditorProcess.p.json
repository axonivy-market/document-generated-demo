      "name" : "previewDocument(cmsContent)",
      "config" : {
        "signature" : "previewDocument",
        "input" : {
          "params" : [
            { "name" : "cmsContent", "type" : "com.axonivy.utils.cmsliveeditor.model.CmsContent", "desc" : "" },
            { "name" : "isEditMode", "type" : "Boolean", "desc" : "" },
            { "name" : "isOnCmsEditColumn", "type" : "Boolean", "desc" : "" }
          ],
          "map" : {
            "out.cmsContent" : "param.cmsContent",
            "out.isEditMode" : "param.isEditMode",
            "out.isOnCmsEditColumn" : "param.isOnCmsEditColumn"
          }
