    }, {
      "id" : "f7",
      "type" : "HtmlDialogEnd",
      "visual" : {
        "at" : { "x" : 432, "y" : 240 },
        "labelOffset" : { "x" : 10, "y" : 30 }
      }
    }, {
      "id" : "f9",
      "type" : "Script",
      "name" : "Convert To StreamContent",
      "config" : {
        "output" : {
          "code" : [
            "import com.axonivy.utils.cmsliveeditor.service.DocumentPreviewService;",
            "",
            "in.fileContent = in.cmsContent.fileContent;",
            "in.fileName = in.cmsContent.fileName;",
            "",
            "if (in.isOnCmsEditColumn) {",
            "  if (in.cmsContent.newFileSize > 0) {",
            "    in.fileContent = in.cmsContent.newFileContent;",
            "  } else if (in.cmsContent.applicationFileSize > 0) {",
            "    in.fileContent = in.cmsContent.applicationFileContent;",
            "  }",
            "} else {",
            "  if (in.cmsContent.applicationFileSize > 0 && !in.isEditMode) {",
            "    in.fileContent = in.cmsContent.applicationFileContent;",
            "  }",
            "}",
            "",
            "in.streamedContent = DocumentPreviewService.getInstance().convertToStreamContent(in.fileName, in.fileContent);"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 264, "y" : 240 },
        "size" : { "width" : 144, "height" : 62 }
      },
      "connect" : [
        { "id" : "f10", "to" : "f7", "color" : "default" }
